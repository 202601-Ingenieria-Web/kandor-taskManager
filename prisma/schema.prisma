generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Enum_UserRole {
  ADMIN
  TEAM_LEADER
  MEMBER
}

enum Enum_TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum Enum_TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Enum_ProjectMemberRole {
  LEADER
  MEMBER
}

enum Enum_MembershipStatus {
  ACTIVE
  PENDING
}

enum Enum_ProjectStatus {
  DRAFT
  ACTIVE
  REJECTED
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  image     String?
  role      Enum_UserRole @default(MEMBER)
  deleted   Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectMemberships ProjectMember[]
  proposedProjects   Project[]
  assignedTasks      TaskAssignment[]
  comments           Comment[]
  timeEntries        TimeEntry[]
}

model Project {
  id          String            @id @default(cuid())
  name        String
  description String?
  color       String?
  status      Enum_ProjectStatus @default(DRAFT)
  deleted     Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  proposedById String?
  proposedBy   User?   @relation(fields: [proposedById], references: [id])

  members ProjectMember[]
  tasks   Task[]
}

model ProjectMember {
  id        String                 @id @default(cuid())
  role      Enum_ProjectMemberRole @default(MEMBER)
  status    Enum_MembershipStatus  @default(ACTIVE)
  joinedAt  DateTime               @default(now())
  userId    String
  projectId String

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Task {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      Enum_TaskStatus @default(TODO)
  priority    Enum_TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  estimatedHours Float?
  deleted     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  parentTaskId String?
  parentTask   Task?  @relation("TaskDependencies", fields: [parentTaskId], references: [id])
  subtasks     Task[] @relation("TaskDependencies")

  assignments  TaskAssignment[]
  comments     Comment[]
  timeEntries  TimeEntry[]
  resources    TaskResource[]
  dependencies TaskDependency[] @relation("DependsOn")
  dependents   TaskDependency[] @relation("DependentTasks")
}

model TaskAssignment {
  id        String   @id @default(cuid())
  assignedAt DateTime @default(now())
  userId    String
  taskId    String

  user User @relation(fields: [userId], references: [id])
  task Task @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
}

model TaskDependency {
  id            String @id @default(cuid())
  taskId        String
  dependsOnId   String

  task       Task @relation("DependsOn", fields: [taskId], references: [id])
  dependsOn  Task @relation("DependentTasks", fields: [dependsOnId], references: [id])

  @@unique([taskId, dependsOnId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task @relation(fields: [taskId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])
}

model Resource {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String?
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskResources TaskResource[]
}

model TaskResource {
  id         String   @id @default(cuid())
  quantity   Float?
  createdAt  DateTime @default(now())

  taskId     String
  task       Task @relation(fields: [taskId], references: [id])

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])

  @@unique([taskId, resourceId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  hours     Float
  description String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])
}

